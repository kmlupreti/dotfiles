#t##################
# options
###################

theme = Ayu
window-theme = ghostty
window-padding-x=5
window-padding-y=2

###################
# keybinds
###################

keybind = alt+j=next_tab
keybind = alt+k=previous_tab
keybind = alt+shift+j=scroll_page_down
keybind = alt+shift+k=scroll_page_up
keybind = alt+t=new_tab
keybind = alt+q=close_tab
keybind = alt+r=reload_config
