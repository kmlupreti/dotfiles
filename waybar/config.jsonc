{
    "output": "eDP-1",
    "modules-left": [
        "niri/workspaces",
        "niri/window"    ],
    "modules-center": [
        "mpris",
    ],
    "modules-right": [
        "wireplumber",
        "battery",
        "clock",
        "tray",
    ],
    "battery": {
        "format": "{icon} {capacity}% ",
        "format-charging": "σΑ²³ {capacity}%",
        "format-full": "σΑ¹Ι {capacity}%",
        "format-icons": ["σΑ¹Κ","σΑ¹Μ","σΑ¹Φ","σΑ¹Ϋ","σΑ¹Ψ","σΑ¹Ω","σΑ²Ä","σΑ²¹","σΑ²²"],
         "states": {
            "warning": 30,
            "critical": 15
    },
        "interval": 5
    },
    "clock": {
        "format": "οêΚ  {:%I:%M %p }",
        "tooltip-format": " ο¹≥  {:%Y-%m-%d %A}",
        "interval": 1,
    },
"wireplumber": {
    "format": "{icon} {volume}% ",
    "format-muted": "ν§Λ ",
    "on-click": "pavucontrol",
    "format-icons": [" οÄΠ "," οÄß ", " οÄ® "],
    "max-volume": 150,
    "scroll-step": 0.2
},
"mpris": {
        // "dynamic-order": ["title","artist"],
        // "dynamic-importance-order" : ["artist","title"],
        // "dynamic-len": 30,
        "interval": 1,
        "format": "{player_icon}  {title} ",
        // "format-paused": "{player_icon} {status_icon} {dynamic} ",
        "player-icons": {
        "default": "οÄ¹ ",
        "mpv": "οç° ",
        "firefox": "σΑàΙ ",
        "vlc": "σΑïΦ "

    	},
    	// "status-icons": {
     //    "playing": " οÖ³  ",
    	// 	"paused": " οä΄  ",
    	// 	"stopped": " οäç  "
    	// }
    },
     "niri/window": {
        "format": "{title}",
        "icon": true,
        "max-length": 50
    },
    "niri/workspaces": {
        "disable-scroll": true,
        "format": "{value}",
        // "persistent-workspaces": {
        //              "*": 4, 
        //        }
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    }
}
